{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Citril",
  "scopeName": "source.citril",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.citril", "match": "//.*$" },
        { "name": "comment.line.number-sign.citril", "match": "#.*$" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.citril",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "name": "constant.character.escape.citril", "match": "\\\\." }]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.citril",
          "match": "\\b(let|fn|if|else|while|return|and|or)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.citril", "match": "\\b\\d+(?:\\.\\d+)?\\b" }
      ]
    },
    "booleans": {
      "patterns": [
        { "name": "constant.language.citril", "match": "\\b(true|false|nil)\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.citril", "match": "==|!=|<=|>=|<|>|=|\\+|-|\\*|/|%|!" }
      ]
    }
  }
}
