include "print_citril_lib"

var x = 0
while (x < 5) {
    localvar label = "x = " + x
    print(label)
    x = x + 1
}

if (x == 5) {
    print("done")
} else {
    print("unexpected")
let x = 0;
while (x < 5) {
    print("x = " + x);
    x = x + 1;
}

if (x == 5) {
    print("done");
} else {
    print("unexpected");
}
